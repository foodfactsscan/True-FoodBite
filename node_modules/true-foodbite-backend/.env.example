PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ─────────────────────────────────────────────────────────────
# MongoDB Atlas (FREE cloud database — data persists forever)
# ─────────────────────────────────────────────────────────────
# Replace with your real MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.abcde.mongodb.net/factsscan?retryWrites=true&w=majority

# ─────────────────────────────────────────────────────────────
# JWT Secret — change this to a random string in production
# ─────────────────────────────────────────────────────────────
JWT_SECRET=factsscan-local-dev-secret-12345

# ─────────────────────────────────────────────────────────────
# Gmail SMTP (App-specific password required)
# ─────────────────────────────────────────────────────────────
# Follow backend/GMAIL-SMTP-SETUP.md for instructions
SMTP_USER=
SMTP_PASS=

# Frontend URL
VITE_BACKEND_URL=http://localhost:5000
