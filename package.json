{
  "name": "true-food-bite",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Root package manager for True FoodBite",
  "engines": {
    "node": "20.x"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npx concurrently -k -c \"blue,green\" -n \"FRONTEND,BACKEND\" \"npm run dev -w frontend\" \"npm run dev -w backend\"",
    "build": "npm run build -w frontend"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongo-sanitize": "^1.1.0",
    "mongoose": "^8.23.0",
    "nodemailer": "^6.9.7",
    "xss-clean": "^0.1.4"
  }
}
